<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Not sandboxed; this is a power-user automation tool distributed with
         Developer ID and notarization, not through the App Store. -->

    <!-- Send Apple Events; volume and other actions drive System Events and
         other apps via AppleScript. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
